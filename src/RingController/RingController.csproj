<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0-android</TargetFramework>
		<SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
		<OutputType>Exe</OutputType>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ApplicationId>com.cysharp.RingController</ApplicationId>
		<ApplicationVersion>1</ApplicationVersion>
		<ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>

		<!-- Linker trimming disabled for CoreCLR device stability -->
		<TrimMode>none</TrimMode>
		<PublishTrimmed>false</PublishTrimmed>
		<!-- CoreCLR (experimental). Custom Views extending Java may emit .java at build time but still hit
		     "no Java peer type found" at runtime (registration differs from Mono).
		     Mitigations when using many custom Views: <UseMonoRuntime>true</UseMonoRuntime>
		     or a thin AndroidJavaSource .java plus C# [Register].
		     Java peer / TrimmableTypeMap handling is evolving for .NET 11 (e.g. dotnet/android #10798). -->
		<UseMonoRuntime>false</UseMonoRuntime>
		<!-- Use NativeAOT -->
		<!--<RuntimeIdentifiers>android-arm64</RuntimeIdentifiers>
		<PublishAot>true</PublishAot>-->
	</PropertyGroup>
	<!-- Release: omit separate PDB so ResolvedSymbols does not hit MSB4096 in Microsoft.Android.Sdk.AssemblyResolution.targets
	     (_PrepareAssemblies batches on %(DestinationSubPath) when PublishTrimmed is false; CoreCLR + net*-android). -->
	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<DebugType>none</DebugType>
	</PropertyGroup>
	<ItemGroup>
		<TrimmerRootDescriptor Include="ILLink.Descriptors.xml" />
	</ItemGroup>
	<ItemGroup>
		<AndroidJavaSource Include="Java\RingAppPickerAdapter.java" />
	</ItemGroup>
</Project>